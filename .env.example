# LiqPay — https://www.liqpay.ua/en/authorization/settings
# Both keys must belong to the same LiqPay account
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=

# Site URL — used as LiqPay result_url after payment
NEXT_PUBLIC_SITE_URL=https://balabony.com

# Telegram bot — https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenAI — used by scripts/generate-timestamps.mjs to auto-generate karaoke timestamps
OPENAI_API_KEY=

# PostgreSQL — editorial review workflow
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Resend — email delivery for editorial workflow
# Get your API key at https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=editorial@balabony.com
